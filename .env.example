APP_ENV=local
PROJECT_NAME=Task Manager
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["*"]
TIMEZONE=Europe/Kiev

POSTGRES_DB=task_manager
POSTGRES_USER=task_manager
POSTGRES_PASSWORD=task_manager
DATABASE_URL=postgresql+asyncpg://task_manager:task_manager@postgres:5432/task_manager

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Set a real token to enable the Telegram bot and deadline notifications.
BOT_TOKEN=
